# KPIs
# =========================================
st.markdown("## 📌 Key Metrics")

kpi1, kpi2, kpi3, kpi4 = st.columns(4)

with kpi1:
    metric_card("Total Customers", format_number(filtered_df.shape[0]), "After selected filters")

with kpi2:
    countries_count = filtered_df["Country"].nunique() if "Country" in filtered_df.columns else "N/A"
    metric_card("Countries", format_number(countries_count), "Unique markets")

with kpi3:
    if "monthly_spending" in filtered_df.columns and not filtered_df.empty:
        avg_spending = filtered_df["monthly_spending"].mean()
        metric_card("Avg Spending", format_number(avg_spending), "Monthly average")
    else:
