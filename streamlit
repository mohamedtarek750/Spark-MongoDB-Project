# =========================================
# MONGODB CONNECTION + LOAD DATA
# =========================================
try:
    client = MongoClient("mongodb://localhost:27017/", serverSelectionTimeoutMS=3000)
    db = client["myProjectDB"]
    collection = db["customers"]
    data = list(collection.find())
except Exception as error:
    st.error(f"Could not connect to MongoDB: {error}")
    st.stop()

df = pd.DataFrame(data)

if df.empty:
    st.warning("No customer data found in MongoDB collection.")
    st.stop()

if "_id" in df.columns:
    df = df.drop("_id", axis=1)

# =========================================
# SIDEBAR FILTERS
# =========================================
st.sidebar.markdown("## ⚙️ Filters")
st.sidebar.caption("Use these filters to focus the dashboard on a smaller customer segment.")

filtered_df = df.copy()

if "Country" in df.columns:
    country_options = ["All"] + sorted(df["Country"].dropna().astype(str).unique().tolist())
    selected_country = st.sidebar.selectbox("Country", country_options)

    if selected_country != "All":
        filtered_df = filtered_df[filtered_df["Country"].astype(str) == selected_country]
else:
    st.sidebar.info("Country column was not found, so the country filter is hidden.")

st.sidebar.markdown("---")
