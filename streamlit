        corr = numeric_df.corr()
        fig8, ax8 = plt.subplots(figsize=(5.4, 3.5), dpi=140)
        cax = ax8.matshow(corr, cmap="Blues")
        ax8.set_xticks(range(len(corr.columns)))
        ax8.set_yticks(range(len(corr.columns)))
        ax8.set_xticklabels(corr.columns, rotation=45, ha="left", fontsize=7)
        ax8.set_yticklabels(corr.columns, fontsize=7)
        ax8.set_title("Numeric Feature Correlation", fontsize=10, fontweight="bold", pad=14)
        fig8.colorbar(cax, fraction=0.045, pad=0.04)
        fig8.tight_layout()
        render_chart(fig8)
    else:
        st.info("At least two numeric columns are required to show a correlation matrix.")

    st.markdown("</div>", unsafe_allow_html=True)

